{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-rhea",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@react-bits": "https://reactbits.dev/r/{name}.json",
    "@retroui": "https://retroui.dev/r/{name}.json",
    "@aceternity": "https://ui.aceternity.com/registry/{name}.json",
    "@ss-components": "https://shadcnstudio.com/r/components/{style}/{name}.json",
    "@ai-elements": "https://ai-sdk.dev/elements/api/registry/{name}.json",
    "@lucide-animated": "https://lucide-animated.com/r/{name}.json",
    "@manifest": "https://ui.manifest.build/r/{name}.json",
    "@aicanvas": "https://aicanvas.me/r/{name}.json",
    "@fluid": "https://www.fluidfunctionalism.com/r/{name}.json",
    "@ncdai": "https://chanhdai.com/r/{name}.json",
    "@shadcnblocks": "https://shadcnblocks.com/r/{name}.json",
    "@cult-ui": "https://cult-ui.com/r/{name}.json",
    "@dotmatrix": "https://dotmatrix.zzzzshawn.cloud/r/{name}.json",
    "@beui": "https://beui.saura3h.xyz/r/{name}.json"
  }
}
